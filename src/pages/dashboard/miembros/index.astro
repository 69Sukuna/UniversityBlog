---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/ui/Button.astro';
import { getUserFromRequest } from '../../../utils/session';
import { requireRole } from '../../../utils/auth';
import { db, Miembros, eq, asc } from 'astro:db';

const user = await getUserFromRequest(Astro.request);

if (!user || !requireRole(user, ['user'])) {
  return Astro.redirect('/login');
}

// Obtener miembros de la sociedad del usuario, ordenados por 'orden'
const miembros = await db
  .select()
  .from(Miembros)
  .where(eq(Miembros.socesId, user.socesId))
  .orderBy(asc(Miembros.orden));

const totalMiembros = miembros.length;

// Color de avatar basado en nombre
const getAvatarColor = (nombre: string) => {
  const colors = [
    'bg-red-500', 'bg-blue-500', 'bg-green-500', 'bg-yellow-500',
    'bg-purple-500', 'bg-pink-500', 'bg-indigo-500', 'bg-teal-500'
  ];
  if (!nombre || typeof nombre !== 'string') return colors[0];
  return colors[nombre.charCodeAt(0) % colors.length];
};

// Iniciales del nombre
const getInitials = (nombre: string) => {
  if (!nombre || typeof nombre !== 'string') return '?';
  return nombre.trim().split(' ').slice(0, 2).map(w => w.charAt(0)).join('').toUpperCase() || '?';
};
---

<Layout title="Miembros - Portal">
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <div class="flex items-center gap-3 mb-2">
            <svg class="w-7 h-7 text-[#023059]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <h2 class="text-3xl font-bold text-gray-900">Directiva</h2>
          </div>
          <div class="flex space-x-3">
            <Button href="/dashboard" variant="secondary">← Volver al Inicio</Button>
            <Button href="/dashboard/miembros/create" variant="primary">+ Nuevo Miembro</Button>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      <div class="px-4 py-6 sm:px-0">

        <!-- Stat Card -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="bg-white overflow-hidden shadow rounded-lg border-l-4 border-blue-500">
            <div class="p-5">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                </div>
                <div class="ml-5 w-0 flex-1">
                  <dl>
                    <dt class="text-sm font-medium text-gray-500 truncate">Total Miembros</dt>
                    <dd class="text-2xl font-bold text-gray-900">{totalMiembros}</dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white overflow-hidden shadow rounded-lg border-l-4 border-purple-500">
            <div class="p-5">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                    </svg>
                  </div>
                </div>
                <div class="ml-5 w-0 flex-1">
                  <dl>
                    <dt class="text-sm font-medium text-gray-500 truncate">Cargos Registrados</dt>
                    <dd class="text-2xl font-bold text-gray-900">
                      {new Set(miembros.map(m => m.cargo)).size}
                    </dd>
                  </dl>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Aviso de orden -->
        {totalMiembros > 1 && (
          <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 mb-6 flex items-center space-x-3">
            <svg class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-blue-700">Usa los botones <strong>↑ ↓</strong> para cambiar el orden de los miembros. El cambio se guarda automáticamente.</p>
          </div>
        )}

        <!-- Lista de miembros -->
        <div class="bg-white shadow overflow-hidden sm:rounded-md">
          <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex justify-between items-center">
            <div>
              <div class="flex items-center gap-3">
                <svg class="w-7 h-7 text-[#023059]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <h3 class="text-lg leading-6 font-medium text-gray-900">Miembros de la Directiva</h3>
              </div>
              <p class="mt-1 text-sm text-gray-500 ml-10">{totalMiembros} miembro{totalMiembros !== 1 ? 's' : ''} registrado{totalMiembros !== 1 ? 's' : ''}</p>
            </div>
          </div>


          {miembros.length === 0 ? (
            <div class="text-center py-12">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">No hay miembros registrados</h3>
              <p class="mt-1 text-sm text-gray-500">Comienza agregando el primer miembro de la directiva.</p>
              <div class="mt-6">
                <Button href="/dashboard/miembros/create" variant="primary">+ Agregar Primer Miembro</Button>
              </div>
            </div>
          ) : (
            <ul class="divide-y divide-gray-200" id="lista-miembros">
              {miembros.map((miembro, index) => (
                <li
                  class="miembro-item px-4 py-5 hover:bg-gray-50 transition-colors duration-150"
                  data-id={miembro.id}
                  data-orden={miembro.orden ?? index + 1}
                >
                  <div class="flex items-center justify-between">
                    <!-- Botones de orden -->
                    <div class="flex flex-col space-y-1 mr-4 flex-shrink-0">
                      <button
                        class="btn-subir p-1 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-800 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
                        data-id={miembro.id}
                        disabled={index === 0}
                        title="Subir"
                      >
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                        </svg>
                      </button>
                      <span class="text-xs text-center text-gray-400 font-mono">{index + 1}</span>
                      <button
                        class="btn-bajar p-1 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-800 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
                        data-id={miembro.id}
                        disabled={index === miembros.length - 1}
                        title="Bajar"
                      >
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </button>
                    </div>

                    <!-- Avatar -->
                    <div class="flex-shrink-0 mr-4">
                      <div class={`h-12 w-12 rounded-full ${getAvatarColor(miembro.nombre)} flex items-center justify-center text-white font-semibold text-sm shadow-md`}>
                        {getInitials(miembro.nombre)}
                      </div>
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                      <h3 class="text-base font-semibold text-gray-900">{miembro.nombre}</h3>
                      <p class="text-sm text-blue-600 font-medium">{miembro.cargo}</p>
                      <div class="flex flex-wrap gap-4 mt-1">
                        {miembro.celular && (
                          <span class="flex items-center text-xs text-gray-500">
                            <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                            {miembro.celular}
                          </span>
                        )}
                        {miembro.correo && (
                          <span class="flex items-center text-xs text-gray-500">
                            <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            {miembro.correo}
                          </span>
                        )}
                      </div>
                    </div>

                    <!-- Acciones -->
                    <div class="flex items-center space-x-2 ml-4 flex-shrink-0">
                      <Button href={`/dashboard/miembros/${miembro.id}/edit`} variant="outline" size="sm">
                        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Editar
                      </Button>
                      <form action="/dashboard/api/miembros/delete" method="POST" class="inline">
                        <input type="hidden" name="miembroId" value={miembro.id} />
                        <button
                          type="submit"
                          onclick="return confirm('¿Eliminar este miembro? Esta acción no se puede deshacer.')"
                          class="inline-flex items-center px-3 py-2 border border-red-300 text-sm leading-4 font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors duration-150"
                        >
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                        </button>
                      </form>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- Footer -->
        <div class="bg-white px-4 py-3 flex items-center justify-center border-t border-gray-200 sm:px-6 mt-6 rounded-lg shadow">
          <p class="text-sm text-gray-700">
            <span class="font-medium">{totalMiembros}</span> miembro{totalMiembros !== 1 ? 's' : ''} en la directiva
          </p>
        </div>

      </div>
    </main>
  </div>

  <!-- Toast de confirmación -->
  <div id="toast" class="hidden fixed bottom-6 right-6 bg-green-600 text-white px-5 py-3 rounded-lg shadow-lg text-sm font-medium transition-all duration-300">
    ✅ Orden actualizado
  </div>

  <script is:inline>
    const lista = document.getElementById('lista-miembros');
    const toast = document.getElementById('toast');

    function mostrarToast() {
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }

    function actualizarBotones() {
      const items = lista.querySelectorAll('.miembro-item');
      items.forEach((item, index) => {
        const btnSubir = item.querySelector('.btn-subir');
        const btnBajar = item.querySelector('.btn-bajar');
        const numLabel = item.querySelector('span.text-xs.text-center');
        btnSubir.disabled = index === 0;
        btnBajar.disabled = index === items.length - 1;
        if (numLabel) numLabel.textContent = index + 1;
      });
    }

    async function guardarOrden() {
      const items = lista.querySelectorAll('.miembro-item');
      const orden = Array.from(items).map((item, index) => ({
        id: Number(item.dataset.id),
        orden: index + 1,
      }));

      try {
        const res = await fetch('/dashboard/api/miembros/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orden }),
        });
        if (res.ok) mostrarToast();
      } catch (e) {
        console.error('Error al guardar orden:', e);
      }
    }

    function moverItem(item, direccion) {
      if (direccion === 'arriba') {
        const anterior = item.previousElementSibling;
        if (anterior) lista.insertBefore(item, anterior);
      } else {
        const siguiente = item.nextElementSibling;
        if (siguiente) lista.insertBefore(siguiente, item);
      }
      actualizarBotones();
      guardarOrden();
    }

    lista?.addEventListener('click', (e) => {
      const btnSubir = e.target.closest('.btn-subir');
      const btnBajar = e.target.closest('.btn-bajar');

      if (btnSubir && !btnSubir.disabled) {
        const item = btnSubir.closest('.miembro-item');
        moverItem(item, 'arriba');
      }
      if (btnBajar && !btnBajar.disabled) {
        const item = btnBajar.closest('.miembro-item');
        moverItem(item, 'abajo');
      }
    });
  </script>

  <style>
    .miembro-item {
      transition: all 0.2s ease;
    }
    .miembro-item:hover {
      transform: translateX(2px);
      box-shadow: 2px 0 8px rgba(0,0,0,0.05);
    }
    #toast {
      z-index: 50;
    }
  </style>
</Layout>