---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/ui/Button.astro';
import { getUserFromRequest } from '../../../utils/session';
import { requireRole } from '../../../utils/auth';
import { db, Miembros, eq } from 'astro:db';

const user = await getUserFromRequest(Astro.request);

if (!user || !requireRole(user, ['user'])) {
  return Astro.redirect('/login');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const nombre = String(formData.get('nombre') || '').trim();
  const cargo = String(formData.get('cargo') || '').trim();
  const celular = String(formData.get('celular') || '').trim();
  const correo = String(formData.get('correo') || '').trim();

  if (!nombre || !cargo) {
    error = 'Nombre y cargo son obligatorios.';
  } else {
    // Calcular el siguiente orden
const miembros = await db.select().from(Miembros).where(eq(Miembros.socesId, user.socesId));
const maxOrden = miembros.length > 0 
  ? miembros.reduce((max, m) => Math.max(max, m.orden ?? 0), 0)
  : 0;

await (db.insert(Miembros) as any).values({
      socesId: user.socesId,
      nombre,
      cargo,
      ...(celular && { celular }),
      ...(correo && { correo }),
      orden: maxOrden + 1,
    });

    return Astro.redirect('/dashboard/miembros');
  }  
}   

---

<Layout title="Nuevo Miembro - Portal">
  <div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">➕ Nuevo Miembro</h1>
            <p class="mt-2 text-sm text-gray-600">Agrega un nuevo miembro a la directiva</p>
          </div>
          <Button href="/dashboard/miembros" variant="secondary">← Volver</Button>
        </div>
      </div>
    </div>

    <main class="max-w-3xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
      {error && (
        <div class="mb-6 bg-red-50 border border-red-300 text-red-700 px-4 py-3 rounded-lg text-sm">
          ⚠️ {error}
        </div>
      )}

      <div class="bg-white shadow rounded-lg p-6">
        <form method="POST" class="space-y-6">
          <!-- Nombre -->
          <div>
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">
              Nombre completo <span class="text-red-500">*</span>
            </label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              required
              placeholder="Ej. Juan Carlos Mamani Quispe"
              class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
            />
          </div>

          <!-- Cargo -->
          <div>
            <label for="cargo" class="block text-sm font-medium text-gray-700 mb-1">
              Cargo <span class="text-red-500">*</span>
            </label>
            <input
              id="cargo"
              name="cargo"
              type="text"
              required
              placeholder="Ej. Presidente, Secretario, Tesorero..."
              class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
            />
          </div>

          <!-- Celular -->
          <div>
            <label for="celular" class="block text-sm font-medium text-gray-700 mb-1">
              Celular <span class="text-gray-400 text-xs">(opcional)</span>
            </label>
            <input
              id="celular"
              name="celular"
              type="text"
              placeholder="Ej. 71234567"
              class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
            />
          </div>

          <!-- Correo -->
          <div>
            <label for="correo" class="block text-sm font-medium text-gray-700 mb-1">
              Correo electrónico <span class="text-gray-400 text-xs">(opcional)</span>
            </label>
            <input
              id="correo"
              name="correo"
              type="email"
              placeholder="Ej. nombre@ejemplo.com"
              class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
            />
          </div>

          <!-- Botones -->
          <div class="flex justify-end space-x-3 pt-4 border-t border-gray-100">
            <Button href="/dashboard/miembros" variant="secondary">Cancelar</Button>
            <button
              type="submit"
              class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
            >
              ✅ Guardar Miembro
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
</Layout>