---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import { BRAND } from 'astro:schema';
import FlipCard from '../../components/ui/MemberCardSimple.astro';
import ImageFocusGallery from '../../components/ui/ImageFocusGallery.astro';
import CardsNotices from '../../components/ui/CardsNotices.astro';
import { db, News, eq , desc } from 'astro:db';

// Obtener noticias de la Soce con id = 1
const noticias = await db
  .select()
  .from(News)
  .where(eq(News.socesId, 11))
  .orderBy(desc(News.fecha)); // Ordenar por fecha (más reciente primero)

const items = [
  {
    img: '/Image/SocSISinf/Logo_carrera1.png',
    text: 'Carrera de Ing. de Sistemas',
    text_URL: 'https://www.sisinf.fni.uto.edu.bo/',
  },
    {
    img: '/Image/SocSISinf/Logo_carrera2.png',
    text: 'Carrera de Ing. de Sistemas',
    text_URL: 'https://www.sisinf.fni.uto.edu.bo/',
  },
  {
    img: '/Image/SocSISinf/Logo_Soc.png',
    text: 'SoCiE-ISII',
    text_URL: 'https://www.facebook.com/SOCIEISII',
  },
];


---

<Layout
  title="SOCEI-ISII"
  description="Bienvenido a mi aplicación construida con Astro y las mejores prácticas de desarrollo web"
>
  <!-- ======================= PRESENTACIÓN ======================= -->
 <section class="bg-[#023059] rounded-2xl mx-4 mt-4 px-6 py-7 relative overflow-hidden">
  <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-white/5"></div>
  <div class="absolute -bottom-12 -left-8 w-32 h-32 rounded-full bg-white/5"></div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
    <div>
      <div class="flex gap-2 flex-wrap mb-4">
        <span class="bg-red-400/15 border border-red-400/40 text-red-400 text-xs font-medium px-3 py-1 rounded-full tracking-wide">
          Universidad Técnica de Oruro
        </span>
        <span class="bg-red-400/15 border border-red-400/40 text-red-400 text-xs font-medium px-3 py-1 rounded-full tracking-wide">
          Facultad Nacional de Ingeniería
        </span>
      </div>

      <h1 class="text-3xl font-bold text-white leading-tight mb-3">
        Sociedad Científica de Estudiantes<br>
        de <span class="text-red-400 italic">Ingeniería de Sistemas e Ingeniería Informática</span>
      </h1>

      <div class="w-10 h-0.5 bg-teal-300/50 mb-4 rounded"></div>

      <p class="text-white/60 text-sm leading-relaxed mb-6 max-w-lg text-justify">
              Un viernes 26 de mayo de 2017, un grupo de estudiantes de la carrera de Ing. de
              Sistemas e Ing. Informática se reunió en ambientes de la carrera con el fin de crear
              una sociedad que pueda contribuir al desarrollo profesional y personal de los
              estudiantes y poder promover el desarrollo de la investigación científica. En aquel
              entonces, el asesor de la sociedad era el M.Sc. Ing. Carlos Balderrama Vásquez,
              gracias al entusiasmo del ingeniero podemos contar con una sociedad científica en la
              carrera que pertenecemos.
      </p>

      <div class="flex items-center gap-4 flex-wrap">
        <a href="#noticias" class="inline-flex items-center gap-2 bg-red-400 text-black text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-red-500 transition-colors">
          Ver noticias
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#mision" class="text-white/50 text-sm hover:text-white/80 transition-colors underline underline-offset-4">
          Misión y Visión
        </a>
      </div>

      <div class="flex gap-6 mt-7 pt-5 border-t border-white/10">
        <div>
          <span class="block text-2xl font-bold text-red-400">2017</span>
          <span class="text-white/40 text-xs mt-0.5 block">Año de fundación</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-red-400">F.N.I.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Facultad</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-red-400">U.T.O.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Universidad</span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <div class="rounded-xl overflow-hidden bg-white/8 border border-white/10 p-4">
        <ImageFocusGallery items={items} textColor="text-white" columnsPerRow={3} />
      </div>
    </div>
  </div>
</section>

   <!-- ======================= NOTICIAS ======================= -->
  <section class="max-w-5xl mx-auto px-6 py-12" id="noticias">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Noticias</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
    <CardsNotices noticias={noticias} />
  </section>


<!-- ======================= DIRECTIVA ======================= -->
  <section class="max-w-5xl mx-auto px-6 py-12" id="direc">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Nuestra Directiva</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
        <div class="flex flex-wrap justify-center gap-6">
          <FlipCard
            name="Univ. LAIZ ARACELY CHURA CHOQUE "
            role="Presidente de la Sociedad Científica SoCiE-ISII"
            email="laiz.chura@sistemas.edu.bo"
            phone="+591 64759552"
            photo="/src/Image/SocSISinf/Presi.jpeg"
          />
          <FlipCard
            name="Univ. Derlis Josué Tintares Choque"
            role="Vicepresidente de la Sociedad Científica SoCiE-ISII"
            email="derlis.tintares@sistemas.edu.bo"
            phone="+591 63141914"
            photo="/src/Image/SocSISinf/Vice.jpeg"
          />
          <FlipCard
            name="Univ. José Daniel García Escobar"
            role="Secretario General de la Sociedad Científica SoCiE-ISII"
            email="jose.garcia@sistemas.edu.bo"
            phone="+591 75715664"
            photo="/src/Image/SocSISinf/General.jpg"

          />
          <FlipCard
            name="Univ. Madelaine Melanie Caro Coca"
            role="Secretaria de Actas de la Sociedad Científica SoCiE-ISII"
            email="madelainecaro.11.02@gmail.com"
            phone="+591 68322386"
            photo="/src/Image/SocSISinf/Actas.jpeg"
            
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ======================= MISION Y VISION ======================= -->
   <section class="max-w-5xl mx-auto px-6 pb-12" id="mision">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Misión y Visión</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-gray-100 rounded-2xl p-6 border-t-4 border-t-[#023059] hover:shadow-md transition-shadow">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-[#023059]/10 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-[#023059]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Nuestra Misión</h3>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed text-justify">
          La SOCIEDAD CIENTÍFICA DE  ESTUDIANTES DE INGENIERÍA DE SISTEMAS E INGENIERÍA INFORMÁTICA (SoCiE-ISII.) 
          es una organización creada para incentivar a la investigación científica dentro de
            la carrera de Ingeniería de Sistemas e Ingeniería Informática, fomentando la participación activa 
            de los estudiantes en temas que ayuden en la enseñanza- aprendizaje.
        </p>
      </div>

      <div class="bg-white border border-gray-100 rounded-2xl p-6 border-t-4 border-t-amber-400 hover:shadow-md transition-shadow">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Nuestra Visión</h3>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed text-justify">
                La SOCIEDAD CIENTÍFICA DE  ESTUDIANTES DE INGENIERÍA DE SISTEMAS E INGENIERÍA INFORMÁTICA (SoCiE-ISII.), 
                será una entidad que refleje una cultura de investigación y planificación formando jóvenes con ideas 
                innovadoras, socialmente comprometida y solidaria con plena participación de sus miembros, considerada 
                la cuna de la ciencia dentro la Carrera de Sistemas e Informática, sirviendo de modelo a través del 
                cumplimiento de sus principios.
        </p>
      </div>
    </div>
  </section>
</Layout>
