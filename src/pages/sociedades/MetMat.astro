---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import { BRAND } from 'astro:schema';
import Carousel from '../../components/ui/Carousel.astro';
import FlipCard from '../../components/ui/MemberCardSimple.astro';
import ImageFocusGallery from '../../components/ui/ImageFocusGallery.astro';
import CardsNotices from '../../components/ui/CardsNotices.astro';
import { db, News, eq , desc} from 'astro:db';

// Obtener noticias de la Soce con id = 1
const noticias = await db
  .select()
  .from(News)
  .where(eq(News.socesId, 4))
  .orderBy(desc(News.fecha)); // Ordenar por fecha (más reciente primero)

const items = [
  {
    img: '/Image/SocMetMat/Logo_carrera1.png',
    text: 'Carrera de Ing. de Mertalurgia y Materiales',
    text_URL: 'https://www.facebook.com/metalurgia.materiales.uto.fni/',
  },
  {
    img: '/Image/SocMetMat/Logo_Soc.jpg',
    text: 'SOCEI MET-MAT',
    text_URL: 'https://www.facebook.com/share/1DmkWMq78A/',
  },
];

---

<Layout
  title="SOCEI MET-MAT"
  description="Bienvenido a mi aplicación construida con Astro y las mejores prácticas de desarrollo web"
>
  <!-- ======================= PRESENTACIÓN ======================= -->
  <section class="bg-[#1e2535] rounded-2xl mx-4 mt-4 px-6 py-7 relative overflow-hidden">
  <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-white/5"></div>
  <div class="absolute -bottom-12 -left-8 w-32 h-32 rounded-full bg-white/5"></div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
    <div>
      <div class="flex gap-2 flex-wrap mb-4">
       <span class="bg-red-300/15 border border-red-300/40 text-red-300 text-xs font-medium px-3 py-1 rounded-full tracking-wide">
        Universidad Técnica de Oruro
      </span>
      <span class="bg-red-300/15 border border-red-300/40 text-red-300 text-xs font-medium px-3 py-1 rounded-full tracking-wide">
        Facultad Nacional de Ingeniería
      </span>
      </div>

      <h1 class="text-3xl font-bold text-white leading-tight mb-3">
        Sociedad Científica de Estudiantes<br>
        de <span class="text-red-500 italic">Ingeniería de Metalurgia y Materiales</span>
      </h1>

      <div class="w-10 h-0.5 bg-red-400/50 mb-4 rounded"></div>

      <p class="text-white/60 text-sm leading-relaxed mb-6 max-w-lg text-justify">
         
      </p>

      <div class="flex items-center gap-4 flex-wrap">
       <a href="#noticias" class="inline-flex items-center gap-2 bg-red-300 text-black text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-red-400 transition-colors">
          Ver noticias
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#mision" class="text-white/50 text-sm hover:text-white/80 transition-colors underline underline-offset-4">
          Misión y Visión
        </a>
      </div>

      <div class="flex gap-6 mt-7 pt-5 border-t border-white/10">
        <div>
          <span class="block text-2xl font-bold text-red-400"></span>
          <span class="text-white/40 text-xs mt-0.5 block">Año de fundación</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-red-400">F.N.I.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Facultad</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-red-400  ">U.T.O.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Universidad</span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <div class="rounded-xl overflow-hidden bg-white/8 border border-white/10 p-4">
        <ImageFocusGallery items={items} textColor="text-white" columnsPerRow={2} />
      </div>
    </div>
  </div>
</section>

 

  <!-- ======================= NOTICIAS ======================= -->
   <section class="max-w-5xl mx-auto px-6 py-12" id="noticias">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Noticias</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
    <CardsNotices noticias={noticias} />
  </section>

  <!-- ======================= DIRECTIVA ======================= -->
  <section class="max-w-5xl mx-auto px-6 py-12" id="direc">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Nuestra Directiva</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
        <div class="flex flex-wrap justify-center gap-6">
          <FlipCard
            name="Univ. Marvin Cruz Main"
            role="Presidente de la Sociedad Científica SOCEI MET-MAT"
            email=" marvincruzmain04@gmail.com"
            phone="+591 74476325"
            photo="/Image/SocMetMat/Presi.png"
          />
          <FlipCard
            name="Univ. Kevin Aldrin Ajhuacho Pozo"
            role="Vicepresidente de la Sociedad Científica SOCEI MET-MAT"
            email="ajhuachopozokevinaldrin@gmail.com"
            phone="+591 78680027"
            photo=""
          />
          <FlipCard
            name="Univ. Esperanza Escalera Sanchez "
            role="Secretaria de Actas de la Sociedad Científica SOCEI MET-MAT"
            email="esperanzasanchez.e@metalurgia.edu.bo"
            phone="+591 71185663"
            photo="/Image/SocMetMat/Actas.png"

          />
          <FlipCard
            name="Univ. Esperanza Mauricio Bernard Garcia Duran"
            role="Secretario de Hacienda de la Sociedad Científica SOCEI MET-MAT"
            biografia={[
              "Profesional altamente capacitado con una sólida formación en ingeniería y gestión ambiental, complementada por estudios de posgrado en administración y sistemas de calidad. Inició su trayectoria académica en 1996, obteniendo el título de Técnico Medio en Programación de Computadoras en el Centro de Asistencia Técnica. Posteriormente, cursó la carrera de Ingeniería Química con mención en Procesos Químicos en la Universidad Técnica de Oruro, finalizando en 1998.",
              "En el año 2001, concluyó una Maestría en Ingeniería Ambiental en la Universidad Politécnica, consolidando su perfil técnico con una perspectiva enfocada en sostenibilidad. A lo largo de su carrera, se especializó en sistemas de gestión, obteniendo dos especialidades en normas ISO: ISO 9000 (2004) e ISO 14000 (2008), a través del Instituto Boliviano de Normalización.",
              "En 2010, completó una Maestría en Administración de Empresas en una universidad privada, lo cual le permitió fortalecer su enfoque estratégico y de liderazgo. Actualmente, continúa su desarrollo profesional cursando Ingeniería Metalúrgica en la Universidad Técnica de Oruro, con estudios programados hasta el año 2025."
            ]}
            email="mauriciogarcia.e@metalurgia.edu.bo"
            phone="+591 77473337"
            photo="/Image/SocMetMat/Hacienda.png"
          />
          <FlipCard
            name="Univ. Leonor Flores Gutierrez"
            role="Vocal de la Sociedad Científica SOCEI MET-MAT"
            email="leonorfloresgutierrez543@gmail.com"
            phone="+591 74107446"
            photo=""

          />
          <FlipCard
            name="Univ. Javier Pablo Rosales Taquichiri "
            role="Vocal de la Sociedad Científica SOCEI MET-MAT"
            email="javierpablorosalestaquichiri@gmail.com "
            phone="+591 68324883"
            photo="/Image/SocMetMat/Vocal.png"

          />
        </div>
      </div>
    </div>
  </section>

  <!-- ======================= MISION Y VISION ======================= -->
   <section class="max-w-5xl mx-auto px-6 pb-12" id="mision">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Misión y Visión</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-gray-100 rounded-2xl p-6 border-t-4 border-t-[#023059] hover:shadow-md transition-shadow">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-[#023059]/10 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-[#023059]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Nuestra Misión</h3>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed text-justify">
           Promover el desarrollo científico, tecnológico y académico de los estudiantes de 
            la carrera de Ingeniería Metalúrgica y Ciencia de Materiales, mediante la investigación, 
            la divulgación del conocimiento con el entorno productivo y la formación integral, 
            contribuyendo en el avance de la ciencia y progreso del país.
        </p>
      </div>

      <div class="bg-white border border-gray-100 rounded-2xl p-6 border-t-4 border-t-amber-400 hover:shadow-md transition-shadow">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Nuestra Visión</h3>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed text-justify">
           Ser una sociedad científica estudiantil activa y comprometida, que fomente la 
            participación estudiantil en actividades de investigación, capacitación y difusión 
            del conocimiento en el área de la Metalurgia y Ciencia de Materiales, fortaleciendo 
            la formación profesional y contribuyendo gradualmente al desarrollo de la carrera y la 
            facultad de ingeniería.
        </p>
      </div>
    </div>
  </section>

   <!-- ======================= REFERENCIAS / REQUISITOS ======================= -->
  <section class="max-w-5xl mx-auto px-6 pb-16" id="unirse">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">¿Cómo ser parte?</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="bg-white border border-gray-100 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-blue-50 rounded-2xl mx-auto mb-4 flex items-center justify-center">
          <svg class="w-6 h-6 text-[#023059]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Matrícula Universitaria</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Presenta tu matrícula del semestre actual.
        </p>
        <a href="https://matricula.uto.edu.bo/" target="_blank" class="inline-block mt-3 text-xs text-[#023059] font-medium hover:underline">
          Consulta tu matrícula →
        </a>
      </div>

      <div class="bg-white border border-gray-100 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-green-50 rounded-2xl mx-auto mb-4 flex items-center justify-center">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/>
          </svg>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Carnet de Identidad</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Carnet de identidad o carnet universitario para identificarte.
        </p>
      </div>

      <div class="bg-white border border-gray-100 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-amber-50 rounded-2xl mx-auto mb-4 flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-2">Formulario de Inscripción</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Formulario de no participación de alguna entidad política o partidaria.
        </p>
        <a href="https://docs.google.com/spreadsheets/d/1FtsuWQa7_OlWuXJzL_LDw1zUMV1zT7FC/edit" target="_blank" class="inline-block mt-3 text-xs text-[#023059] font-medium hover:underline">
          Ir al formulario →
        </a>
      </div>

    </div>
  </section>
</Layout>
