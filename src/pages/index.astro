---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import { BRAND } from 'astro:schema';
import Carousel from '../components/ui/Carousel.astro';
import CardsNotices from '../components/ui/CardsNotices.astro';
import FlipCard from '../components/ui/Target.astro';
import { db, News, Convocatorias, eq, desc } from 'astro:db';

// Obtener noticias de la Soce con id = 1, ordenadas por fecha (más reciente primero)
const noticias = await db
  .select()
  .from(News)
  .where(eq(News.socesId, 1))
  .orderBy(desc(News.fecha)); // Ordenar por fecha (más reciente primero)

const convocatorias = await db
  .select()
  .from(Convocatorias)
  .orderBy(desc(Convocatorias.fecha)); // Ordenar por fecha (más reciente primero)

//carrusell
const modules = import.meta.glob('../../public/Image/fotosGen/*.{png,jpg,jpeg,gif}', { eager: true });

const images = Object.values(modules)
  .map(mod => {
    if (typeof mod === 'string') return { src: mod };
    if (mod && typeof mod === 'object' && 'default' in mod) return mod.default;
    if (mod && typeof mod === 'object' && 'src' in mod) return mod;
    return null;
  })
  .filter(Boolean);
---


<Layout
  title="OSCE - FNI"
  description="Bienvenido a mi aplicación construida con Astro y las mejores prácticas de desarrollo web"
>
  <!-- ======================= PRESENTACIÓN ======================= -->
<section class="bg-[#023059] rounded-2xl mx-4 mt-4 px-6 py-7 relative overflow-hidden">
  <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-white/5"></div>
  <div class="absolute -bottom-12 -left-8 w-32 h-32 rounded-full bg-white/5"></div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">

    <!-- Columna izquierda -->
    <div>
      <div class="flex gap-2 flex-wrap mb-4">
        <span class="bg-amber-300/15 border border-amber-300/40 text-amber-300 text-xs font-medium px-3 py-1 rounded-full tracking-wide">
          Universidad Técnica de Oruro
        </span>
        <span class="bg-amber-300/15 border border-amber-300/40 text-amber-300 text-xs font-medium px-3 py-1 rounded-full tracking-wide">
          Facultad Nacional de Ingeniería
        </span>
      </div>

      <h1 class="text-3xl font-bold text-white leading-tight mb-3">
        Sociedades Científicas<br>
        de la <span class="text-amber-300 italic">F.N.I.</span>
      </h1>

      <div class="w-10 h-0.5 bg-amber-300/50 mb-4 rounded"></div>

      <p class="text-white/60 text-sm leading-relaxed mb-6 max-w-lg text-justify">
        Las sociedades científicas contribuyen al desarrollo estudiantil y al desarrollo profesional
        forjando jóvenes con ganas de aprender y que tengan la valentía de sobresalir entre todos los demás.
        <br><br>Por ello, la Facultad Nacional de Ingeniería de la Universidad Técnica de Oruro comprende con 11 
        sociedades científicas actualmente, las cuales son representadas por la Organización de Sociedades Científicas de Estudiantes de la F.N.I. (OSCE-FNI)
      </p>

      <div class="flex items-center gap-4 flex-wrap">
        <a href="#historia" class="inline-flex items-center gap-2 bg-amber-300 text-[#023059] text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-amber-200 transition-colors">
          Conocer más
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#direc" class="text-white/50 text-sm hover:text-white/80 transition-colors underline underline-offset-4">
          Ver autoridades
        </a>
      </div>

      <!-- Stats -->
      <div class="flex gap-6 mt-7 pt-5 border-t border-white/10">
        <div>
          <span class="block text-2xl font-bold text-amber-300">11</span>
          <span class="text-white/40 text-xs mt-0.5 block">Sociedades activas</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-amber-300">U.T.O.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Universidad</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-amber-300">F.N.I.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Facultad</span>
        </div>
      </div>
    </div>

    <!-- Columna derecha -->
<div class="flex flex-col gap-4">
  <div class="flex items-center justify-center gap-5 bg-white/8 border border-white/10 rounded-xl px-6 py-4">
    <a href="https://www.fni.uto.edu.bo/" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="../../public/Image/FNI.png" alt="Logo FNI" class="w-14 h-auto object-contain" />
      <span class="text-white/50 text-xs text-center leading-tight">Facultad Nacional<br>de Ingeniería</span>
    </a>
    <div class="w-px h-14 bg-white/15"></div>
    <a href="https://www.facebook.com/profile.php?id=100095466616159" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="../../public/Image/OSCE.png" alt="Logo OSCE" class="w-16 h-auto object-contain" />
      <span class="text-white/50 text-xs text-center leading-tight">Organización de Sociedades<br>Científicas de Estudiantes</span>
    </a>
  </div>
  <div class="rounded-xl overflow-hidden bg-white/8 border border-white/10 p-3">
    <Carousel images={images} />
  </div>
</div>

  </div>
</section>

  <!-- ======================= HISTORIA ======================= -->
 <section class="max-w-5xl mx-auto px-6 py-12" id="historia">
    <h2 class="text-3xl font-bold text-gray-900 mb-2">Historia</h2>
    <div class="w-9 h-1 bg-[#023059] rounded mb-6"></div>
    <div class="space-y-4">
      <div class="bg-gray-50 border-l-4 border-[#023059] rounded-xl px-6 py-4">
        <p class="text-gray-600 text-sm leading-relaxed text-justify">
           La Organización de Sociedades Científicas Estudiantiles (OSCE-FNI) fue creada hace 
            algunos años con el propósito de unificar y coordinar todas las sociedades científicas 
            pertenecientes a la Facultad Nacional de Ingeniería (FNI). Su objetivo principal es modernizar 
            y reestructurar el enfoque tradicional, muchas veces fragmentado y desactualizado, que existía 
            en la gestión y funcionamiento de estas sociedades.
          </p>
      </div>
      <div class="bg-gray-50 border-l-4 border-[#023059] rounded-xl px-6 py-4 text-justify">
        <p class="text-gray-600 text-sm leading-relaxed">
           A través de OSCE-FNI, se busca fomentar la colaboración entre las diferentes sociedades, 
            potenciar el desarrollo académico y científico de los estudiantes, así como promover actividades 
            conjuntas que enriquezcan la formación integral dentro de la facultad. Esta organización actúa como 
            un ente rector que facilita la comunicación, planificación y ejecución de proyectos que beneficien 
            a toda la comunidad estudiantil de la FNI, promoviendo un sentido de pertenencia, innovación y trabajo 
            en equipo.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================= AUTORIDADES ======================= -->
  <section class=" bg-white py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">      
      <div class="text-center mb-16" id="direc">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Nuestras Autoridades</h2>
        <div class="flex flex-wrap justify-center gap-6">
          <FlipCard 
            name="M.Sc. Ing. Carlos Antonio Flores Castillo"
            role="Decano de la Facultad Nacional de Ingeniería"
            biografia=""
            email=""
            phone=""
            photo="../public/Image/Im_Inicio/Decano.jpg"

          /> 
          <FlipCard 
            name="Dr. Ing. Roberto Del Barco Gamarra"
            role="Vicedecano de la Facultad Nacional de Ingeniería"
            biografia=""
            email=""
            phone=""
            photo="../public/Image/Im_Inicio/Vicedecano.jpg"

          />
          <FlipCard 
            name="M.Sc. Ing. Pedro Román Vallejos Mamani"
            role="Director de la Dirección de Investigación Científica y Tecnolófica U.T.O. (DICyT)"
            biografia=""
            email=""
            phone="+591 72462547"
            photo="../public/Image/Im_Inicio/Dicyt.jpg"

          />  
                          
        </div>

        
      </div>

  </section>

  <!-- ======================= CONVOCATORIAS ======================= -->

<section class="bg-white py-10 px-6 sm:px-12 lg:px-16" id="convocatorias">
  <div class="flex flex-wrap gap-6 items-start">
    <h2 class="w-full text-center text-3xl font-bold text-gray-900 mb-4">
      Convocatorias
    </h2>
    <!-- Mostrar convocatorias -->
    <CardsNotices noticias={convocatorias} />
  </div>
</section>

  <!-- ======================= NOTICIAS ======================= -->

<section class="bg-white py-10 px-6 sm:px-12 lg:px-16" id="noticias">
  <div class="flex flex-wrap gap-6 items-start">
    <h2 class="w-full text-center text-3xl font-bold text-gray-900 mb-4">
      Noticias 
    </h2>
    <!-- Mostrar noticias OSCE -->
    <CardsNotices noticias={noticias} />
  </div>
</section>


</Layout>
