      </div>
    </div>

    <!-- Columna derecha -->
<div class="flex flex-col gap-4">
  <div class="flex items-center justify-center gap-5 bg-white/8 border border-white/10 rounded-xl px-6 py-4">
    <a href="https://www.fni.uto.edu.bo/" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="../public/Image/FNI.png" alt="Logo FNI" class="w-14 h-auto object-contain" />
