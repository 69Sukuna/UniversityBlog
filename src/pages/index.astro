        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-amber-300">U.T.O.</span>
          <span class="text-white/40 text-xs mt-0.5 block">Universidad</span>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <span class="block text-2xl font-bold text-amber-300">F.N.I.</span>
