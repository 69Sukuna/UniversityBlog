---
const pathname = Astro.url.pathname;

const baseNavItems = [
  { name: 'Inicio', href: '/' },
  { 
    name: 'Sociedades Científicas Parte 1', 
    href: '/',
    children: [
      { name: 'So.C.E. Ing. Minas', href: '/sociedades/Min' },
      { name: 'So.C.E. Ing. Civil', href: '/sociedades/Civ' },
      { name: 'So.C.E. Ing. Metalurgia y Materiales', href: '/sociedades/MetMat' },
      { 
        name: 'So.C.E. Ing. Mecánica Electromecánica Mecatrónica', 
        href: '/sociedades/Mec',
        children: [
          { name: 'So.C.E. SCEIMEM', href: '/sociedades/Mec' },
          { name: 'Sub-sociedad COM', href: '/sociedades/COM' },
          { name: 'Sub-sociedad SIDDFAC', href: '/sociedades/SIDDFAC' }
        ]
      },
      { name: 'So.C.E. Ing. Eléctrica - Ing. Electrónica', href: '/sociedades/Elec' },
      { name: 'So.C.E. Ing. Química e Ing. de Alimentos', href: '/sociedades/Quim' },
    ]
  },
  {
    name: 'Sociedades Científicas Parte 2',
    href: '/',
    children: [
      { name: 'So.C.E. Ing. Geológica', href: '/sociedades/Geo' },
      { name: 'So.C.E. Ing. de Sistemas e Ing. Informática', href: '/sociedades/SISinf' },
      { name: 'So.C.E. Ing. Industrial', href: '/sociedades/Ind' },
      { name: 'So.C.E. del Departamento de Física de Ciclo Básico', href: '/sociedades/Fis' },
      { name: 'So.C.E. del Departamento de Química', href: '/sociedades/Cons' },
    ]
  },
  { name: 'Noticias', href: '#noticias' },
  { name: 'Autoridades - Directiva', href: '#direc' },
  { name: 'Enlaces', href: '#enlaces' }
];

const navItems = pathname === '/' 
  ? [...baseNavItems.slice(0, 3), { name: 'Convocatorias', href: '#convocatorias' }, ...baseNavItems.slice(3)]
  : baseNavItems;

const soloItems = navItems.filter(i => !i.children);
const groupItems = navItems.filter(i => i.children);
const inicioItem = soloItems[0];
const paginaItems = soloItems.slice(1);
---

<nav class="flex flex-col gap-1 px-2">

  <!-- INICIO -->
  <div class="mb-3">
    <p class="text-white/30 text-xs uppercase tracking-widest px-2 mb-2">Menú</p>
    
    <a  href={inicioItem.href}
      class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 ${pathname === inicioItem.href ? 'bg-amber-300/20 text-amber-300' : 'text-white/70 hover:text-white hover:bg-white/8'}`}
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      {inicioItem.name}
    </a>
  </div>

  <!-- SOCIEDADES -->
  <div class="mb-3">
    <p class="text-white/30 text-xs uppercase tracking-widest px-2 mb-2">Sociedades</p>
    {groupItems.map((item, i) => (
      <div class="nav-item mb-1 relative">
        
        <a  href={item.href}
          class="flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium text-white/70 hover:text-white hover:bg-white/8 transition-all duration-200"
        >
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <span class="text-left leading-tight">{item.name}</span>
          </div>
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>

        <!-- Submenu nivel 1 -->
        <div class="submenu-level-1">
          {item.children && item.children.map((child, j) => (
            <div class="submenu-item relative">
              {child.children ? (
                <div>
                  
                  <a  href={child.href}
                    class="submenu-link flex items-center justify-between px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/8 transition-all duration-200"
                  >
                    <span>{child.name}</span>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                  <!-- Submenu nivel 2 -->
                  <div class="submenu-level-2">
                    <div class="px-3 py-2 text-xs font-semibold text-amber-300/60 uppercase tracking-wider border-b border-white/10 mb-1">
                      {child.name}
                    </div>
                    {child.children.map((grandchild) => (
                      
                      <a  href={grandchild.href}
                        class={`block px-4 py-2 text-sm transition-all duration-200 ${pathname === grandchild.href ? 'text-amber-300 bg-amber-300/10' : 'text-white/70 hover:text-white hover:bg-white/8'}`}
                      >
                        {grandchild.name}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                
                <a  href={child.href}
                  class={`block px-4 py-2.5 text-sm transition-all duration-200 ${pathname === child.href ? 'text-amber-300 bg-amber-300/10' : 'text-white/70 hover:text-white hover:bg-white/8'}`}
                >
                  {child.name}
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- PÁGINA -->
  <div>
    <p class="text-white/30 text-xs uppercase tracking-widest px-2 mb-2">Página</p>
    {paginaItems.map((item) => (
      
      <a  href={item.href}
        data-scroll={item.href.startsWith('#') ? item.href.substring(1) : ''}
        class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 mb-1 ${item.name === 'Convocatorias' ? 'bg-amber-300/20 text-amber-300 hover:bg-amber-300/30' : 'text-white/70 hover:text-white hover:bg-white/8'}`}
      >
        {item.name === 'Convocatorias' && (
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
        )}
        {item.name === 'Noticias' && (
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
        )}
        {item.name === 'Autoridades - Directiva' && (
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        )}
        {item.name === 'Enlaces' && (
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
        )}
        {item.name}
      </a>
    ))}
  </div>

</nav>

<style>
  .submenu-level-1 {
    position: absolute;
    right: 100%;
    top: 0;
    margin-right: 8px;
    width: 280px;
    background: #012443;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    z-index: 50;
    opacity: 0;
    visibility: hidden;
    transform: translateX(8px);
    transition: all 0.2s ease-in-out;
    padding: 6px;
  }

  .nav-item:hover .submenu-level-1 {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }

  .submenu-level-1:hover {
    opacity: 1;
    visibility: visible;
  }

  .submenu-level-2 {
    position: absolute;
    right: 100%;
    top: 0;
    margin-right: 8px;
    width: 240px;
    background: #012443;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    z-index: 60;
    opacity: 0;
    visibility: hidden;
    transform: translateX(8px);
    transition: all 0.2s ease-in-out;
    padding: 6px;
  }

  .submenu-item:hover .submenu-level-2 {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }

  .submenu-level-2:hover {
    opacity: 1;
    visibility: visible;
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-scroll]').forEach(link => {
    const id = link.getAttribute('data-scroll');
    if (id) {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  });
</script>